# C200 爆款视频复刻 —— 本地环境变量（复制为 .env.local 后填值；.env.local 不进 git）

# ── 生图 线路 banana（gpt-image-2，即用户的 "Image2"，默认）──
# 复用 A700 同一套 BananaRouter key。支持文生图 + 图生图(images.edit)。
BANANA_API_KEY=<bananarouter sk-...>
BANANA_API_URL=https://api.bananarouter.com/v1
BANANA_MODEL=gpt-image-2

# ── 生图 线路 seedream（火山方舟豆包 Seedream，备选/兜底）──
# 若 gpt-image-2 不支持图生图，一键切到这条（route=seedream）。
IMAGE_API_KEY=<火山方舟 ARK_API_KEY>
IMAGE_API_URL=https://ark.cn-beijing.volces.com/api/v3
IMAGE_MODEL=doubao-seedream-5-0-260128
IMAGE_WATERMARK=false

# ── 画面理解 vision（豆包，逐镜描述，复用上面火山 ARK key）──
# 默认就复用 IMAGE_API_KEY + IMAGE_API_URL，无需另填；只在想换模型/换 key 时设下面两个。
# 已验证可用模型：doubao-seed-1-6-250615（详细）/ doubao-seed-1-6-flash-250615（快省）。
VLM_MODEL=doubao-seed-1-6-250615
# VLM_API_KEY=    # 留空则用 IMAGE_API_KEY
# VLM_API_URL=    # 留空则用 IMAGE_API_URL

# ── 视频生成 Seedance（图生视频，火山方舟，Step3）──
# 按次计费，故意单独一把 key、不复用上面的 IMAGE_API_KEY。留空 = 不启用视频生成（Step3 会提示去配）。
# 要用就填火山视频生成 key（可与 IMAGE_API_KEY 同值，也可单独一把便于单独计费/限额）。
VIDEO_API_KEY=
# VIDEO_API_URL=    # 留空用 IMAGE_API_URL（同一个火山 ARK 端点）
# VIDEO_MODEL=doubao-seedance-1-0-pro-250528

# ── 冒烟测试默认线路（banana / seedream）──
SMOKE_ROUTE=banana
