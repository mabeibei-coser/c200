# C200 爆款视频复刻 —— 本地环境变量（复制为 .env.local 后填值；.env.local 不进 git）

# ── 生图 线路 banana（gpt-image-2，即用户的 "Image2"，默认）──
# 复用 A700 同一套 BananaRouter key。支持文生图 + 图生图(images.edit)。
BANANA_API_KEY=<bananarouter sk-...>
BANANA_API_URL=https://api.bananarouter.com/v1
BANANA_MODEL=gpt-image-2

# ── 画面理解 vision（讯飞 Qwen-VL，OpenAI 兼容；已从豆包换来）──
# 用讯飞 key（可与你其他项目的 IFLYTEK_API_KEY 同一把复用）。实测可看图、出结构化描述、还比豆包快。
VLM_API_KEY=<讯飞 key>
VLM_API_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
VLM_MODEL=xopqwen36v35b
# 想换回豆包：VLM_API_KEY 填火山 key、VLM_API_URL=https://ark.cn-beijing.volces.com/api/v3、VLM_MODEL=doubao-seed-1-6-250615

# ── 视频生成 Seedance（图生视频，火山方舟，Step3）──
# 按次计费。留空 = 不启用视频生成（Step3 会提示去配）。要用就填火山视频生成 key。
VIDEO_API_KEY=
# VIDEO_API_URL=    # 留空用火山 ARK 默认端点 https://ark.cn-beijing.volces.com/api/v3
# VIDEO_MODEL=doubao-seedance-1-0-pro-250528

# ── 冒烟测试（生图线路，固定 banana=gpt-image-2）──
SMOKE_ROUTE=banana
